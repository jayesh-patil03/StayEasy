<% layout('/layouts/boilerplate') -%>

<section>
  <div class="detail-grid">
    <article class="detail-panel">
      <div class="detail-media-wrap">
        <img
          src="<%= listing.image.url %>"
          class="detail-image"
          alt="<%= listing.title %>"
        />
        <span class="detail-badge">
          <i class="fa-solid fa-star"></i>
          Highly rated stay
        </span>
      </div>

      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <span class="eyebrow">
            <i class="fa-solid fa-house-circle-check"></i>
            Verified listing
          </span>
          <h1 class="detail-title mt-3 mb-2"><%= listing.title %></h1>
          <p class="detail-description mb-0">
            <i class="fa-solid fa-location-dot me-2"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>
        </div>
      </div>

      <div class="detail-summary">
        <span class="detail-chip">
          <i class="fa-solid fa-indian-rupee-sign"></i>
          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
        </span>
        <span class="detail-chip">
          <i class="fa-solid fa-comments"></i>
          <%= listing.reviews.length %> review<%= listing.reviews.length === 1 ? '' : 's' %>
        </span>
        <span class="detail-chip">
          <i class="fa-solid fa-moon"></i>
          Dark mode ready
        </span>
      </div>

      <div class="detail-owner mb-4">
        <span class="avatar-pill">
          <%= listing.owner.username.charAt(0).toUpperCase() %>
        </span>
        <div>
          <strong class="d-block">Hosted by <%= listing.owner.username %></strong>
          <span class="muted-copy">Trusted StayEasy host</span>
        </div>
      </div>

      <h2 class="section-title h4 mb-2">About this place</h2>
      <p class="detail-description mb-0"><%= listing.description %></p>
    </article>

    <aside class="detail-side-panel">
      <div class="booking-card">
        <p class="muted-copy text-uppercase fw-semibold small mb-2">Reserve your stay</p>
        <div class="price-block mb-2">
          <strong>&#8377; <%= listing.price.toLocaleString("en-IN") %></strong>
          <span class="muted-copy">per night</span>
        </div>
        <p class="muted-copy mb-0">
          Clear property details, better spacing, and improved readability across desktop and mobile.
        </p>

        <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="detail-actions">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-brand btn-pill flex-fill">
              Edit listing
            </a>
            <form
              method="post"
              action="/listings/<%= listing._id %>?_method=DELETE"
              class="flex-fill"
            >
              <button class="btn btn-danger-soft btn-pill w-100">Delete listing</button>
            </form>
          </div>
        <% } %>
      </div>

      <div class="info-card">
        <h2 class="section-title h5 mb-3">Quick facts</h2>
        <div class="d-grid gap-3">
          <div class="detail-chip">
            <i class="fa-solid fa-bed"></i>
            Well-designed place presentation
          </div>
          <div class="detail-chip">
            <i class="fa-solid fa-mobile-screen-button"></i>
            Optimized for compact mobile screens
          </div>
          <div class="detail-chip">
            <i class="fa-solid fa-shield-heart"></i>
            Easy-to-read alerts and forms
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="review-layout">
    <% if (currUser) { %>
      <section class="review-form-panel">
        <span class="eyebrow">
          <i class="fa-solid fa-pen"></i>
          Share your experience
        </span>
        <h2 class="section-title h4 mt-3 mb-2">Leave a review</h2>
        <p class="section-copy">Tell future guests what stood out about this stay.</p>

        <form
          action="/listings/<%= listing._id %>/reviews"
          method="post"
          novalidate
          class="needs-validation"
        >
          <div class="mt-3 mb-4">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot mb-0">
              <input
                type="radio"
                id="no-rate"
                class="input-no-rate"
                name="review[rating]"
                value="1"
                checked
                aria-label="No rating."
              />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Your review</label>
            <textarea
              name="review[comment]"
              id="comment"
              class="form-control"
              rows="5"
              placeholder="What did you love about the stay?"
              required
            ></textarea>
            <div class="invalid-feedback">Please add a short review before submitting.</div>
          </div>

          <button class="btn btn-brand btn-pill w-100">Submit review</button>
        </form>
      </section>
    <% } %>

    <section class="review-list-panel">
      <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
        <div>
          <h2 class="section-title h4 mb-1">Guest reviews</h2>
          <p class="section-copy mb-0">Modern cards with better hierarchy and spacing.</p>
        </div>
      </div>

      <% if (listing.reviews.length) { %>
        <div class="review-grid">
          <% for (review of listing.reviews) { %>
            <article class="review-card">
              <div class="review-card-head">
                <div class="review-author">
                  <span class="avatar-pill">
                    <%= review.author.username.charAt(0).toUpperCase() %>
                  </span>
                  <div>
                    <strong class="d-block"><%= review.author.username %></strong>
                    <span class="muted-copy small">Verified guest</span>
                  </div>
                </div>
                <p
                  class="starability-result mb-0"
                  data-rating="<%= review.rating %>"
                  style="font-size: 18px"
                ></p>
              </div>

              <p class="review-comment"><%= review.comment %></p>

              <form
                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                method="post"
              >
                <button class="btn btn-soft btn-pill w-100">Remove review</button>
              </form>
            </article>
          <% } %>
        </div>
      <% } else { %>
        <div class="content-panel empty-state">
          <h3 class="section-title h5 mb-2">No reviews yet</h3>
          <p class="section-copy mb-0">Be the first guest to share what this place feels like.</p>
        </div>
      <% } %>
    </section>
  </div>
</section>
