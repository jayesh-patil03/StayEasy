<% layout('/layouts/boilerplate') -%>

<section>
  <div class="detail-grid">
    <article class="detail-panel">
      <div class="detail-media-wrap">
        <img
          src="<%= listing.image.url %>"
          class="detail-image"
          alt="<%= listing.title %>"
        />
        <span class="detail-badge">
          <i class="fa-solid fa-house"></i>
          <%= listing.roomType || "PG" %>
        </span>
        <span class="listing-status detail-status <%= listing.available === false ? 'is-unavailable' : 'is-available' %>">
          <%= listing.available === false ? "Not Available" : "Available" %>
        </span>
      </div>

      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
        <div>
          <span class="eyebrow">
            <i class="fa-solid fa-door-open"></i>
            RoomEase verified listing
          </span>
          <h1 class="detail-title mt-3 mb-2"><%= listing.title %></h1>
          <p class="detail-description mb-0">
            <i class="fa-solid fa-location-dot me-2"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>
        </div>
      </div>

      <div class="detail-summary">
        <span class="detail-chip">
          <i class="fa-solid fa-indian-rupee-sign"></i>
          &#8377; <%= listing.displayRent.toLocaleString("en-IN") %> / month
        </span>
        <span class="detail-chip">
          <i class="fa-solid fa-wallet"></i>
          Deposit &#8377; <%= (listing.deposit || 0).toLocaleString("en-IN") %>
        </span>
        <span class="detail-chip">
          <i class="fa-solid fa-couch"></i>
          <%= listing.furnished ? "Furnished" : "Semi/Unfurnished" %>
        </span>
        <span class="detail-chip">
          <i class="fa-solid fa-user-group"></i>
          <%= listing.genderPreference || "Any" %>
        </span>
      </div>

      <div class="detail-owner mb-4">
        <span class="avatar-pill">
          <%= listing.owner.username.charAt(0).toUpperCase() %>
        </span>
        <div>
          <strong class="d-block">Listed by <%= listing.owner.username %></strong>
          <span class="muted-copy">
            <%= currUser ? listing.owner.email : "Log in to view owner contact details" %>
          </span>
        </div>
      </div>

      <h2 class="section-title h4 mb-2">About this room</h2>
      <p class="detail-description mb-4"><%= listing.description %></p>

      <h2 class="section-title h4 mb-3">Amenities</h2>
      <div class="amenity-pill-wrap">
        <% if (listing.amenities && listing.amenities.length) { %>
          <% listing.amenities.forEach((amenity) => { %>
            <span class="amenity-pill"><%= amenity %></span>
          <% }) %>
        <% } else { %>
          <span class="muted-copy">No amenities added yet.</span>
        <% } %>
      </div>
    </article>

    <aside class="detail-side-panel">
      <div class="booking-card">
        <p class="muted-copy text-uppercase fw-semibold small mb-2">Room summary</p>
        <div class="price-block mb-2">
          <strong>&#8377; <%= listing.displayRent.toLocaleString("en-IN") %></strong>
          <span class="muted-copy">per month</span>
        </div>
        <p class="muted-copy mb-0">
          <%= listing.available === false ? "This room is currently marked unavailable." : "This room is currently open for inquiries." %>
        </p>

        <div class="detail-actions">
          <% if (currUser && currUser.role === "tenant") { %>
            <% if (isSaved) { %>
              <form action="/wishlist/<%= listing._id %>?_method=DELETE" method="POST" class="flex-fill">
                <button class="btn btn-danger-soft btn-pill w-100">Remove from wishlist</button>
              </form>
            <% } else { %>
              <form action="/wishlist/<%= listing._id %>" method="POST" class="flex-fill">
                <button class="btn btn-brand btn-pill w-100">Save to wishlist</button>
              </form>
            <% } %>
          <% } %>

          <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-brand btn-pill flex-fill">
              Edit room
            </a>
            <form
              method="post"
              action="/listings/<%= listing._id %>?_method=DELETE"
              class="flex-fill"
            >
              <button class="btn btn-danger-soft btn-pill w-100">Delete room</button>
            </form>
          <% } %>
        </div>
      </div>

      <div class="info-card">
        <h2 class="section-title h5 mb-3">Quick facts</h2>
        <div class="d-grid gap-3">
          <div class="detail-chip">
            <i class="fa-solid fa-house-laptop"></i>
            <%= listing.roomType || "PG" %> setup
          </div>
          <div class="detail-chip">
            <i class="fa-solid fa-people-roof"></i>
            Best suited for <%= listing.genderPreference || "Any" %>
          </div>
          <div class="detail-chip">
            <i class="fa-solid fa-bolt"></i>
            <%= listing.available === false ? "Currently unavailable" : "Available for contact" %>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <div class="review-layout">
    <section class="review-form-panel">
      <% if (currUser && currUser.role === "tenant" && !currUser._id.equals(listing.owner._id)) { %>
        <span class="eyebrow">
          <i class="fa-solid fa-paper-plane"></i>
          Contact owner
        </span>
        <h2 class="section-title h4 mt-3 mb-2">Send an inquiry</h2>
        <p class="section-copy">Ask about move-in date, deposit details, or nearby facilities.</p>

        <form action="/contact/<%= listing._id %>" method="POST" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="message" class="form-label">Message</label>
            <textarea
              id="message"
              name="inquiry[message]"
              class="form-control"
              rows="4"
              placeholder="Hi, I am interested in this room. Is it still available?"
              required
            ></textarea>
            <div class="invalid-feedback">Please add a message for the owner.</div>
          </div>

          <button class="btn btn-brand btn-pill w-100">Contact owner</button>
        </form>

        <hr class="my-4" />
      <% } %>

      <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
        <span class="eyebrow">
          <i class="fa-solid fa-inbox"></i>
          Tenant inquiries
        </span>
        <h2 class="section-title h4 mt-3 mb-2">Messages from interested tenants</h2>
        <p class="section-copy">Track inquiry messages received for this room listing.</p>

        <% if (inquiries.length) { %>
          <div class="inquiry-list">
            <% inquiries.forEach((inquiry) => { %>
              <article class="inquiry-card">
                <strong class="d-block"><%= inquiry.tenantId.username %></strong>
                <span class="muted-copy small d-block mb-2"><%= inquiry.tenantId.email %></span>
                <p class="mb-0"><%= inquiry.message %></p>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="content-panel empty-state">
            <h3 class="section-title h5 mb-2">No inquiries yet</h3>
            <p class="section-copy mb-0">Tenant messages will appear here once someone contacts you.</p>
          </div>
        <% } %>
      <% } %>

      <% if (currUser && currUser.role === "tenant") { %>
        <hr class="my-4" />
        <span class="eyebrow">
          <i class="fa-solid fa-pen"></i>
          Share your experience
        </span>
        <h2 class="section-title h4 mt-3 mb-2">Leave a review</h2>
        <p class="section-copy">Help other tenants understand how this room and owner experience felt.</p>

        <form
          action="/listings/<%= listing._id %>/reviews"
          method="post"
          novalidate
          class="needs-validation"
        >
          <div class="mt-3 mb-4">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot mb-0">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>

          <div class="mb-3">
            <label for="comment" class="form-label">Your review</label>
            <textarea
              name="review[comment]"
              id="comment"
              class="form-control"
              rows="5"
              placeholder="How was the room, location, and owner communication?"
              required
            ></textarea>
            <div class="invalid-feedback">Please add a short review before submitting.</div>
          </div>

          <button class="btn btn-brand btn-pill w-100">Submit review</button>
        </form>
      <% } else if (!currUser) { %>
        <span class="eyebrow">
          <i class="fa-solid fa-right-to-bracket"></i>
          Join RoomEase
        </span>
        <h2 class="section-title h4 mt-3 mb-2">Log in to contact the owner</h2>
        <p class="section-copy mb-3">
          Create a tenant account to save this room, message the owner, and leave a review later.
        </p>
        <div class="d-flex flex-wrap gap-2">
          <a href="/login" class="btn btn-brand btn-pill">Login</a>
          <a href="/signup" class="btn btn-soft btn-pill">Create account</a>
        </div>
      <% } %>
    </section>

    <section class="review-list-panel">
      <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
        <div>
          <h2 class="section-title h4 mb-1">Tenant reviews</h2>
          <p class="section-copy mb-0">See what previous visitors said about the room and owner.</p>
        </div>
      </div>

      <% if (listing.reviews.length) { %>
        <div class="review-grid">
          <% for (review of listing.reviews) { %>
            <article class="review-card">
              <div class="review-card-head">
                <div class="review-author">
                  <span class="avatar-pill">
                    <%= review.author.username.charAt(0).toUpperCase() %>
                  </span>
                  <div>
                    <strong class="d-block"><%= review.author.username %></strong>
                    <span class="muted-copy small">RoomEase member</span>
                  </div>
                </div>
                <p
                  class="starability-result mb-0"
                  data-rating="<%= review.rating %>"
                  style="font-size: 18px"
                ></p>
              </div>

              <p class="review-comment"><%= review.comment %></p>

              <% if (currUser && review.author._id.equals(currUser._id)) { %>
                <form
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                  method="post"
                >
                  <button class="btn btn-soft btn-pill w-100">Remove review</button>
                </form>
              <% } %>
            </article>
          <% } %>
        </div>
      <% } else { %>
        <div class="content-panel empty-state">
          <h3 class="section-title h5 mb-2">No reviews yet</h3>
          <p class="section-copy mb-0">Be the first tenant to share feedback about this room.</p>
        </div>
      <% } %>
    </section>
  </div>
</section>
