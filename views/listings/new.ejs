<% layout('/layouts/boilerplate') -%>
<body>
  <div class="row mt-3">
    <div class="col-12 col-md-8 offset-md-2">
      <h3><b>Create new Listing</b></h3>
      <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-2">
          <label for="title" class="form-label">Title</label>
          <input name="listing[title]" type="text" class="form-control" required/>
          <div class="invalid-feedback">Title should be valid</div>
        </div>
        
        <div class="mb-2">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listing[description]"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">Description should be valid</div>
        </div>


        <div class="mb-2">
          <label for="image" class="form-label">Upload Listing Image</label>
          <input name="listing[image]"  type="file" class="form-control" required />
        </div>

        <div class="row">
          <div class="col-12 col-md-4 mb-2">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]"  type="number" class="form-control" required />
            <div class="invalid-feedback">Price should be valid</div>
          </div>
        
          <div class="col-12 col-md-8 mb-2">
            <label for="loaction" class="form-label">Location</label>
            <input name="listing[location]"  type="text" class="form-control" required/>
            <div class="invalid-feedback">Location should be valid</div>
          </div>
        </div>

        <div class="mb-2">
          <label for="country" class="form-label">Country</label>
          <input name="listing[country]"  type="text" class="form-control" required/>
          <div class="invalid-feedback">Country should be valid</div>
        </div>

        <button class="btn btn-dark add-btn mt-3 w-100 rounded-pill">add listing</button>
      </form>
      <br><br>
    </div>
  </div>
</body>
