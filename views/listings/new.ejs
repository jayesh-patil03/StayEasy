<% layout('/layouts/boilerplate') -%>

<section class="form-wrapper">
  <div class="form-grid">
    <aside class="form-showcase content-panel">
      <span class="eyebrow">
        <i class="fa-solid fa-building-user"></i>
        Owner workspace
      </span>
      <h1 class="form-title mt-3 mb-3">List a room that tenants can trust at first glance.</h1>
      <p class="form-helper mb-0">
        Add rent details, room type, amenities, and availability so students and working
        professionals can quickly decide if your property is a fit.
      </p>

      <div class="feature-list">
        <div class="feature-item">
          <i class="fa-solid fa-bed"></i>
          Highlight room type, furnished status, and gender preference
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-money-bill-wave"></i>
          Set monthly rent and security deposit clearly
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-circle-check"></i>
          Keep availability updated for better tenant trust
        </div>
      </div>
    </aside>

    <div class="form-panel content-panel">
      <h2 class="form-title mb-2">Create room listing</h2>
      <p class="form-helper mb-4">Publish a room listing with the details tenants care about most.</p>

      <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Room title</label>
          <input
            id="title"
            name="listing[title]"
            type="text"
            class="form-control"
            placeholder="Furnished PG near metro station"
            required
          />
          <div class="invalid-feedback">Please enter a valid room title.</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            id="description"
            name="listing[description]"
            class="form-control"
            placeholder="Describe the room, nearby facilities, and the type of tenant this room suits best."
            required
          ></textarea>
          <div class="invalid-feedback">Please enter a valid description.</div>
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Upload room image</label>
          <input
            id="image"
            name="listing[image]"
            type="file"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please upload a room image.</div>
        </div>

        <div class="row g-3">
          <div class="col-12 col-md-6">
            <label for="rent" class="form-label">Rent per month</label>
            <input
              id="rent"
              name="listing[rent]"
              type="number"
              class="form-control"
              placeholder="8500"
              required
            />
            <div class="invalid-feedback">Please enter valid rent.</div>
          </div>

          <div class="col-12 col-md-6">
            <label for="deposit" class="form-label">Deposit</label>
            <input
              id="deposit"
              name="listing[deposit]"
              type="number"
              class="form-control"
              placeholder="15000"
              required
            />
            <div class="invalid-feedback">Please enter valid deposit.</div>
          </div>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-12 col-md-6">
            <label for="roomType" class="form-label">Room type</label>
            <select id="roomType" name="listing[roomType]" class="form-select" required>
              <option value="">Select room type</option>
              <option value="PG">PG</option>
              <option value="1BHK">1BHK</option>
              <option value="2BHK">2BHK</option>
              <option value="Shared">Shared</option>
            </select>
            <div class="invalid-feedback">Please select room type.</div>
          </div>

          <div class="col-12 col-md-6">
            <label for="genderPreference" class="form-label">Gender preference</label>
            <select id="genderPreference" name="listing[genderPreference]" class="form-select" required>
              <option value="">Select preference</option>
              <option value="Male">Male</option>
              <option value="Female">Female</option>
              <option value="Any">Any</option>
            </select>
            <div class="invalid-feedback">Please select gender preference.</div>
          </div>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-12 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input
              id="location"
              name="listing[location]"
              type="text"
              class="form-control"
              placeholder="Pune"
              required
            />
            <div class="invalid-feedback">Please enter a valid location.</div>
          </div>

          <div class="col-12 col-md-4">
            <label for="country" class="form-label">Country</label>
            <input
              id="country"
              name="listing[country]"
              type="text"
              class="form-control"
              placeholder="India"
              required
            />
            <div class="invalid-feedback">Please enter a valid country.</div>
          </div>
        </div>

        <div class="mt-3">
          <label class="form-label d-block">Amenities</label>
          <div class="amenity-selector">
            <% amenityOptions.forEach((amenity) => { %>
              <label class="amenity-option">
                <input type="checkbox" name="listing[amenities]" value="<%= amenity %>" />
                <span><%= amenity %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-12 col-md-6">
            <label class="form-label d-block">Furnished</label>
            <label class="toggle-option">
              <input type="checkbox" name="listing[furnished]" value="true" />
              <span>Yes, this room is furnished</span>
            </label>
          </div>

          <div class="col-12 col-md-6">
            <label class="form-label d-block">Availability</label>
            <label class="toggle-option">
              <input type="checkbox" name="listing[available]" value="true" checked />
              <span>Available for tenants right now</span>
            </label>
          </div>
        </div>

        <div class="form-card-note">
          <i class="fa-solid fa-lightbulb"></i>
          Detailed listings help tenants shortlist rooms faster and reduce unnecessary inquiries.
        </div>

        <button class="btn btn-brand btn-pill mt-4 w-100">Publish room</button>
      </form>
    </div>
  </div>
</section>
