<% layout('/layouts/boilerplate') -%>

<section class="form-wrapper">
  <div class="form-grid">
    <aside class="form-showcase content-panel">
      <span class="eyebrow">
        <i class="fa-solid fa-wand-magic-sparkles"></i>
        Host beautifully
      </span>
      <h1 class="form-title mt-3 mb-3">Create a listing that feels trusted at first glance.</h1>
      <p class="form-helper mb-0">
        Better structure, cleaner fields, and more breathing space help your property feel
        premium before guests even click.
      </p>

      <div class="feature-list">
        <div class="feature-item">
          <i class="fa-solid fa-image"></i>
          Strong image-first presentation with cleaner hierarchy
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-mobile-screen"></i>
          Form spacing tuned for desktop and mobile
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-circle-info"></i>
          Easier-to-read property info for future guests
        </div>
      </div>
    </aside>

    <div class="form-panel content-panel">
      <h2 class="form-title mb-2">Create new listing</h2>
      <p class="form-helper mb-4">Fill in the details below to publish your property.</p>

      <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Listing title</label>
          <input
            id="title"
            name="listing[title]"
            type="text"
            class="form-control"
            placeholder="Modern loft with skyline views"
            required
          />
          <div class="invalid-feedback">Please enter a valid title.</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            id="description"
            name="listing[description]"
            class="form-control"
            placeholder="Describe the vibe, amenities, and why guests will love staying here."
            required
          ></textarea>
          <div class="invalid-feedback">Please enter a valid description.</div>
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Upload listing image</label>
          <input
            id="image"
            name="listing[image]"
            type="file"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please upload a property image.</div>
        </div>

        <div class="row g-3">
          <div class="col-12 col-md-4">
            <label for="price" class="form-label">Price per night</label>
            <input
              id="price"
              name="listing[price]"
              type="number"
              class="form-control"
              placeholder="4500"
              required
            />
            <div class="invalid-feedback">Please enter a valid price.</div>
          </div>

          <div class="col-12 col-md-8">
            <label for="location" class="form-label">Location</label>
            <input
              id="location"
              name="listing[location]"
              type="text"
              class="form-control"
              placeholder="Mumbai"
              required
            />
            <div class="invalid-feedback">Please enter a valid location.</div>
          </div>
        </div>

        <div class="mt-3">
          <label for="country" class="form-label">Country</label>
          <input
            id="country"
            name="listing[country]"
            type="text"
            class="form-control"
            placeholder="India"
            required
          />
          <div class="invalid-feedback">Please enter a valid country.</div>
        </div>

        <div class="form-card-note">
          <i class="fa-solid fa-lightbulb"></i>
          Listings with clear descriptions and strong images usually feel more trustworthy.
        </div>

        <button class="btn btn-brand btn-pill mt-4 w-100">Publish listing</button>
      </form>
    </div>
  </div>
</section>
