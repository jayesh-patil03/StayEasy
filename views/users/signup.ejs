<% layout('/layouts/boilerplate') -%>

<section class="auth-wrapper">
  <div class="auth-grid">
    <aside class="auth-showcase auth-panel">
      <span class="eyebrow">
        <i class="fa-solid fa-user-plus"></i>
        Join RoomEase
      </span>
      <h1 class="auth-title mt-3 mb-3">Create your account to rent or list rooms with confidence.</h1>
      <p class="auth-copy mb-0">
        RoomEase helps owners publish verified room listings and helps tenants find spaces that
        fit their rent, room type, and lifestyle preferences.
      </p>

      <div class="feature-list">
        <div class="feature-item">
          <i class="fa-solid fa-house"></i>
          Browse student and working professional room listings
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-heart"></i>
          Save rooms to your wishlist
        </div>
        <div class="feature-item">
          <i class="fa-solid fa-comments"></i>
          Contact owners directly from the listing page
        </div>
      </div>
    </aside>

    <div class="auth-panel content-panel">
      <h2 class="auth-title mb-2">Create your RoomEase account</h2>
      <p class="auth-copy mb-4">Choose whether you are joining as a room owner or a tenant.</p>

      <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input
            name="username"
            id="username"
            type="text"
            class="form-control"
            placeholder="Choose a username"
            required
          />
          <div class="invalid-feedback">Please enter a username.</div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input
            name="email"
            id="email"
            type="email"
            class="form-control"
            placeholder="you@example.com"
            required
          />
          <div class="invalid-feedback">Please enter a valid email.</div>
        </div>

        <div class="mb-3">
          <label class="form-label d-block">Role</label>
          <div class="role-grid">
            <label class="role-option">
              <input type="radio" name="role" value="tenant" checked />
              <span>
                <strong>Tenant</strong>
                <small>Find rooms, save favorites, and contact owners.</small>
              </span>
            </label>
            <label class="role-option">
              <input type="radio" name="role" value="owner" />
              <span>
                <strong>Owner</strong>
                <small>List rooms, update availability, and manage inquiries.</small>
              </span>
            </label>
          </div>
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <div class="input-group">
            <input
              name="password"
              id="password"
              type="password"
              class="form-control"
              placeholder="Create a password"
              required
            />
            <button
              class="btn password-toggle-btn"
              type="button"
              data-password-toggle
              data-target="password"
            >
              <i class="fa-regular fa-eye me-2"></i>
              Show
            </button>
          </div>
          <div class="invalid-feedback">Please enter a password.</div>
        </div>

        <button class="btn btn-brand btn-pill mt-2 w-100">Create account</button>
      </form>

      <p class="form-helper mt-4 mb-0">
        Already have an account?
        <a href="/login" class="fw-semibold text-decoration-none">Log in here</a>.
      </p>
    </div>
  </div>
</section>
