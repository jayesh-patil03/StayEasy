          <li class="nav-item me-2">
            <a class="btn btn-danger px-3 w-100 w-md-auto" href="/logout">
              Logout
            </a>
          </li>
        <% } %>

        <!-- 🌙 Theme toggle -->
        <li class="nav-item ms-md-2">
          <button id="themeToggle" class="btn btn-outline-secondary px-3 w-100 w-md-auto" type="button">
