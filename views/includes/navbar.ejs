<nav class="navbar navbar-expand-md sticky-top topbar">
  <div class="container-fluid topbar-inner">
    <div class="navbar-frame w-100">
      <div class="navbar-head">
        <div class="navbar-brand-wrap">
          <a class="navbar-brand d-flex align-items-center gap-3 m-0" href="/listings">
            <span class="brand-mark">
              <i class="fa-solid fa-house-chimney"></i>
            </span>
            <span class="navbar-brand-text">
              <strong>StayEasy</strong>
            </span>
          </a>
        </div>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#mainNavbar"
          aria-controls="mainNavbar"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
      </div>

      <div class="collapse navbar-collapse" id="mainNavbar">
        <div class="navbar-layout w-100">
          <ul class="navbar-nav nav-primary">
            <li class="nav-item">
              <a
                class="nav-link <%= currentPath.startsWith('/listings') ? 'active' : '' %>"
                href="/listings"
              >
                Explore stays
              </a>
            </li>

            <% if (currUser) { %>
              <li class="nav-item">
                <a
                  class="nav-link <%= currentPath.startsWith('/listings/new') ? 'active' : '' %>"
                  href="/listings/new"
                >
                  Host a place
                </a>
              </li>
            <% } %>
          </ul>

          <div class="navbar-right">
            <form
              class="topbar-search"
              role="search"
              action="/listings"
              method="GET"
            >
              <input
                class="form-control"
                type="search"
                placeholder="Search by city"
                aria-label="Search listings"
                name="city"
                value="<%= typeof searchCity !== 'undefined' ? searchCity : '' %>"
              />
              <button class="btn search-btn" type="submit" aria-label="Search">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            </form>

            <ul class="navbar-nav topbar-actions">
              <% if (!currUser) { %>
                <li class="nav-item">
                  <a class="btn btn-soft btn-pill" href="/signup">Sign up</a>
                </li>
                <li class="nav-item">
                  <a class="btn btn-soft btn-pill" href="/login">Login</a>
                </li>
              <% } %>

              <% if (currUser) { %>
                <li class="nav-item">
                  <span class="nav-link user-pill">
                    <i class="fa-regular fa-circle-user"></i>
                    <span><%= currUser.username %></span>
                  </span>
                </li>
                <li class="nav-item">
                  <a class="btn btn-danger-soft btn-pill" href="/logout">Logout</a>
                </li>
              <% } %>

              <li class="nav-item">
                <button
                  id="themeToggle"
                  class="btn btn-soft theme-toggle-btn"
                  type="button"
                  aria-label="Toggle theme"
                >
                  <i class="fa-regular fa-moon"></i>
                </button>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
