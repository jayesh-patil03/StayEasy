<% layout('/layouts/boilerplate') -%>

<section class="error-shell">
  <div class="content-panel error-card">
    <span class="eyebrow">
      <i class="fa-solid fa-triangle-exclamation"></i>
      Something went wrong
    </span>
    <h1 class="section-title mt-3 mb-2">We couldn’t load that page.</h1>
    <p class="section-copy mb-4"><%= message %></p>
    <a href="/listings" class="btn btn-brand btn-pill">Back to listings</a>
  </div>
</section>
